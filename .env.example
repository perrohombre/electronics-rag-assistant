APP_ENV=development
LOG_LEVEL=INFO

API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_SERVER_PORT=8501

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=products
CATALOG_DB_PATH=data/catalog.db
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=32
OPENAI_QUERY_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_QUERY_ANALYSIS_TIMEOUT_SECONDS=10
OPENAI_QUERY_ANALYSIS_MAX_BRANDS=200
OPENAI_QUERY_ANALYSIS_MAX_OUTPUT_TOKENS=200
BESTBUY_API_KEY=
BESTBUY_BASE_URL=https://api.bestbuy.com/v1
BESTBUY_TIMEOUT_SECONDS=15.0
BESTBUY_RATE_LIMIT_PER_SECOND=5.0
BESTBUY_MAX_RETRIES=2
BESTBUY_PAGE_SIZE=100
BESTBUY_MAX_PAGES_PER_CATEGORY=3
